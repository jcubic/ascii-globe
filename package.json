{
  "name": "ascii-globe",
  "version": "0.4.4",
  "description": "Isomorphic ASCII globe renderer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./maps/*": {
      "types": "./dist/maps/*.d.ts",
      "import": "./dist/maps/*.js",
      "require": "./dist/maps/*.cjs"
    }
  },
  "bin": {
    "globe": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "extract": "tsx scripts/extract-texture.ts globe.png --output src/maps/earth.ts && tsx scripts/extract-texture.ts death-star.png",
    "build": "tsup",
    "version": "sed -i \"s/npm-[0-9]*\\.[0-9]*\\.[0-9]*/npm-$npm_package_version/\" README.md",
    "prepublishOnly": "npm run build",
    "example:node": "tsx examples/node-animation.ts",
    "example:browser": "echo 'Open examples/browser/index.html via a local server'"
  },
  "keywords": [
    "ascii",
    "globe",
    "terminal",
    "earth",
    "ascii-art"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcubic/ascii-globe.git"
  },
  "bugs": {
    "url": "https://github.com/jcubic/ascii-globe/issues"
  },
  "homepage": "https://github.com/jcubic/ascii-globe#readme",
  "author": "Jakub T. Jankiewicz <jcubic@onet.pl> (https://jakub.jankiewicz.org/)",
  "license": "MIT",
  "devDependencies": {
    "sharp": "^0.33.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
